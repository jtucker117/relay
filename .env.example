# Copy to .env.local and fill in. Vite only exposes vars prefixed with VITE_ to the browser.
# These two are PUBLIC (anon key is safe to ship — RLS is what protects data).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Google Maps JS API key for the Leads map. Public by design — restrict it by
# HTTP referrer (relay.sitestac.com) in Google Cloud Console. Needs billing enabled.
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-js-api-key

# --- Server-side only (Supabase Edge Function secrets — NEVER prefix with VITE_, never ship to browser) ---
# Set these with:  supabase secrets set NAME=value
# ANTHROPIC_API_KEY=sk-ant-...        # AI website-preview generator + lead-search fallback
# GOOGLE_PLACES_API_KEY=...           # lead-search live search (server key, Places API New; NOT the browser Maps key)
# Team invite emails go through Supabase's built-in auth email (no key needed).
# RESEND_API_KEY=re_...               # optional — for higher-volume / own-domain email later
# SUPABASE_SERVICE_ROLE_KEY=...       # used by the preview Edge Function to bypass RLS after email-lock check
# STRIPE_SECRET_KEY=sk_...            # Critical 4 (later)
